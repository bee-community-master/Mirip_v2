# Vast.ai API key from https://cloud.vast.ai/account/
VAST_API_KEY=

# Local SSH public key used for attach ssh-key
VAST_SSH_PUBKEY_PATH=/Users/shawn/.ssh/key_name.pub

# Optional: private key for direct ssh/rsync commands
VAST_SSH_PRIVKEY_PATH=/Users/shawn/.ssh/key_name

# Vast.ai instance id used by train/scripts/vast_ai_training_runner.py sync-prune
VAST_INSTANCE_ID=
