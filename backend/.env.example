MIRIP_APP_ENV=local
MIRIP_DATA_BACKEND=memory
MIRIP_STORAGE_BACKEND=gcs

MIRIP_FIREBASE__ALLOW_INSECURE_DEV_AUTH=true
MIRIP_FIREBASE__LOCAL_DEV_TOKEN=local-dev-token

MIRIP_GCS__PROJECT_ID=mirip-v2
MIRIP_GCS__BUCKET_NAME=mirip-v2-assets
MIRIP_GCS__CREDENTIALS_PATH=/absolute/path/to/mirip-v2-service-account.json
MIRIP_GCS__UPLOAD_URL_TTL_MINUTES=15

MIRIP_WORKER__MODE=stub
