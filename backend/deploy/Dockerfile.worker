FROM ghcr.io/astral-sh/uv:0.8.13-python3.12-bookworm-slim

WORKDIR /app
ARG WORKER_DEPENDENCY_PROFILE=stub

COPY pyproject.toml README.md uv.lock* ./
COPY src ./src
RUN if [ "${WORKER_DEPENDENCY_PROFILE}" = "stub" ]; then \
      uv sync --frozen --no-dev --extra worker; \
    else \
      uv sync --frozen --no-dev --extra worker --extra worker-cpu-onnx; \
    fi

ENV PATH=/app/.venv/bin:$PATH
ENV PYTHONPATH=/app/src

CMD ["python", "-m", "mirip_backend.worker.main"]
