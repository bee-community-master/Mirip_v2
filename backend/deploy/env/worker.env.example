MIRIP_APP_ENV=prod
MIRIP_DATA_BACKEND=firestore
MIRIP_STORAGE_BACKEND=gcs
MIRIP_FIREBASE__PROJECT_ID=your-project-id
MIRIP_FIREBASE__CREDENTIALS_PATH=/secrets/firebase-service-account.json
MIRIP_GCS__PROJECT_ID=your-project-id
MIRIP_GCS__BUCKET_NAME=your-bucket-name
MIRIP_GCS__CREDENTIALS_PATH=/secrets/gcs-service-account.json
MIRIP_WORKER__MODE=cpu_onnx
MIRIP_WORKER__MODEL_URI=gs://your-bucket/models/vitl-serving-bundle
MIRIP_WORKER__LOCAL_MODEL_CACHE_DIR=/var/lib/mirip/model-cache
MIRIP_WORKER__RUN_ONCE=true
MIRIP_COMPUTE__ENABLED=true
MIRIP_COMPUTE__PROJECT_ID=your-project-id
MIRIP_COMPUTE__ZONE=asia-northeast3-b
MIRIP_COMPUTE__INSTANCE_TEMPLATE=global/instanceTemplates/mirip-worker-template
MIRIP_COMPUTE__SERVICE_ACCOUNT=worker@your-project-id.iam.gserviceaccount.com
MIRIP_COMPUTE__SUBNETWORK=regions/asia-northeast3/subnetworks/default
