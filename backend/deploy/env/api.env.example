MIRIP_APP_ENV=prod
MIRIP_DATA_BACKEND=firestore
MIRIP_STORAGE_BACKEND=gcs
MIRIP_FIREBASE__PROJECT_ID=your-project-id
MIRIP_FIREBASE__CREDENTIALS_PATH=/secrets/firebase-service-account.json
